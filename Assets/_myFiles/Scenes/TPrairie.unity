    - target: {fileID: 3498568096948360507, guid: ea4164403dcef01459d0233e3cccc085, type: 3}
      propertyPath: 'mDialogue.Array.data[2]'
      value: Maybe I'll be done later.
      objectReference: {fileID: 0}
    - target: {fileID: 3498568096948360507, guid: ea4164403dcef01459d0233e3cccc085, type: 3}
      propertyPath: 'mDialogue.Array.data[3]'
      value: In the meantime.
      objectReference: {fileID: 0}
    - target: {fileID: 3498568096948360507, guid: ea4164403dcef01459d0233e3cccc085, type: 3}
      propertyPath: 'mDialogue.Array.data[4]'
      value: I am craving some wine!
      objectReference: {fileID: 0}
    - target: {fileID: 3498568096948360507, guid: ea4164403dcef01459d0233e3cccc085, type: 3}
      propertyPath: 'mDialogue.Array.data[5]'
      value: I left it near my house.
      objectReference: {fileID: 0}
    - target: {fileID: 3498568096948360507, guid: ea4164403dcef01459d0233e3cccc085, type: 3}
      propertyPath: 'mDialogue.Array.data[6]'
